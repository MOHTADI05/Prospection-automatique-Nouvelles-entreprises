# ════════════════════════════════════════════════════
#  Copier ce fichier en .env et remplir vos valeurs
#  Ne JAMAIS committer .env dans Git !
# ════════════════════════════════════════════════════

# ── Mode d'envoi ─────────────────────────────────────
# "email"  → test digital gratuit (par défaut)
# "postal" → vraie lettre physique via Maileva
MODE_ENVOI=email

# ── SMTP (requis pour MODE_ENVOI=email) ──────────────
# Exemple avec Gmail : créer un "Mot de passe d'application"
# sur https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application_gmail

# Votre propre email pour recevoir les brochures de test
# (une email par entreprise trouvée)
EMAIL_DESTINATAIRE_TEST=votre_email@gmail.com

# Email pour le rapport de run hebdomadaire (peut être le même)
RAPPORT_DESTINATAIRE=votre_email@gmail.com

# ── Maileva (requis UNIQUEMENT pour MODE_ENVOI=postal) ─
# Inscription sur https://dev.maileva.com
# MAILEVA_TOKEN=votre_token_maileva_ici
